%%{
  init: {
    'theme': 'base',
    'themeVariables': {
      'primaryColor': '#ffffff',
      'primaryBorderColor': '#005CE6',
      'lineColor': '#333333',
      'tertiaryColor': '#f4f4f4',
      'fontFamily': 'system-ui, -apple-system, sans-serif'
    }
  }
}%%
sequenceDiagram
    autonumber
    actor User
    participant PortService as Portfolio Service
    participant Kafka as Apache Kafka
    participant MarketService as Market Data Service

    User->>PortService: POST /api/trades (Buy 10 AAPL)
    activate PortService
    PortService-->>PortService: Create Order (Status: PENDING)
    PortService->>Kafka: Publish Event: OrderPlaced
    PortService-->>User: 202 Accepted (Order Pending)
    deactivate PortService

    Kafka-->>MarketService: Consume: OrderPlaced
    activate MarketService
    MarketService-->>MarketService: Validate Price & Execute Trade

    alt Trade Successful
        MarketService->>Kafka: Publish Event: TradeExecuted
        Kafka-->>PortService: Consume: TradeExecuted
        PortService-->>PortService: Update Order (Status: COMPLETED)
        PortService-->>PortService: Update User Asset Holdings
    else Trade Failed (e.g., Price slippage)
        MarketService->>Kafka: Publish Event: TradeFailed
        Kafka-->>PortService: Consume: TradeFailed
        PortService-->>PortService: COMPENSATING ACTION<br/>Update Order (Status: FAILED)<br/>Refund User Balance
    end
    deactivate MarketService