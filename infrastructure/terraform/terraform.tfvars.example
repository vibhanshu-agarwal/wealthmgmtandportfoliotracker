# =============================================================================
# Terraform Variable Examples — Wealth Management & Portfolio Tracker
# =============================================================================
#
# BOOTSTRAP SEQUENCE (run once before terraform init in this directory):
#   1. cd infrastructure/terraform/bootstrap
#   2. terraform init          # uses local state
#   3. terraform apply -var="state_bucket_name=my-tf-state" \
#                      -var="lock_table_name=my-tf-lock"
#   4. cd ..
#   5. terraform init -backend-config="bucket=my-tf-state" \
#                     -backend-config="dynamodb_table=my-tf-lock" \
#                     -backend-config="region=us-east-1"
#   6. terraform apply -var-file=terraform.tfvars
#
# SECRET INJECTION (never commit real secrets):
#   Sensitive variables are injected via environment variables in CI:
#   export TF_VAR_postgres_connection_string="jdbc:postgresql://..."
#   export TF_VAR_mongodb_connection_string="mongodb+srv://..."
#   export TF_VAR_cloudfront_origin_secret="<random-uuid>"
#
# =============================================================================

# Backend state (must match bootstrap outputs)
state_bucket_name = "my-wealth-tracker-tf-state"
lock_table_name   = "my-wealth-tracker-tf-lock"

# AWS configuration
aws_region                    = "us-east-1"
use_localstack                = false
# Paid RDS + ElastiCache (default false)
enable_aws_managed_database = false
# Optional Lambda VPC attachment (only when enable_aws_managed_database=true and private endpoints are required)
lambda_vpc_subnet_ids         = []
lambda_vpc_security_group_ids = []

# S3 artifact bucket
artifact_bucket_name = "my-wealth-tracker-artifacts"

# Frontend static export bucket
frontend_bucket_name = "my-wealth-tracker-frontend"

# api-gateway Lambda container (package_type Image — must exist in ECR before first apply)
api_gateway_image_uri = "123456789012.dkr.ecr.us-east-1.amazonaws.com/my-api-gateway:latest"

# Service Lambda containers (package_type Image — must exist in ECR before first apply)
# portfolio_image_uri   = "123456789012.dkr.ecr.us-east-1.amazonaws.com/wealth-portfolio-service:latest"
# market_data_image_uri = "123456789012.dkr.ecr.us-east-1.amazonaws.com/wealth-market-data-service:latest"
# insight_image_uri     = "123456789012.dkr.ecr.us-east-1.amazonaws.com/wealth-insight-service:latest"

# Lambda ISA — default is "arm64" (Graviton2, 20% cheaper per GB-s).
# Uncomment and set to "x86_64" ONLY to roll back after a failed arm64 deployment.
# lambda_architecture = "x86_64"

# ---------------------------------------------------------------------------
# Phase 2 — EventBridge Scheduler warming (docs/architecture/lambda-stopgap-execution-plan.md §5)
# Flip enable_warming to true ONLY after Phase 1 (arm64 flip) is confirmed stable for >= 48 h.
# All variables below are required when enable_warming = true.
# ---------------------------------------------------------------------------
# enable_warming = false
#
# Email address that receives the SNS ConcurrentExecutions alarm.
# AWS sends a confirmation email immediately after apply — click "Confirm subscription".
# warming_alarm_email = "you@example.com"
#
# Optional: override warming cadence (default "rate(5 minutes)").
# warming_schedule_cron = "rate(5 minutes)"
#
# Optional: override concurrency alarm threshold (default 8, 2 below the 10-unit limit).
# warming_concurrent_executions_threshold = 8

# Optional overrides for Lambda memory (defaults live in locals.tf → lambda_defaults)
# portfolio_memory_size       = 2048
# market_data_memory_size     = 1024
# insight_service_memory_size = 1024

# Current auth path: api-gateway issues and validates HS256 JWTs for one demo user.
# Do not commit real values; supply these via TF_VAR_* / GitHub Actions secrets.
# Leave the example blank so secret scanners do not treat placeholder text as a key.
auth_jwt_secret  = ""
app_auth_email   = "demo@example.com"
app_auth_password = "replace-with-demo-password"
app_auth_user_id = "00000000-0000-0000-0000-000000000e2e"
app_auth_name    = "Demo User"

# Reserved for a future external IdP/JWK profile; not used by the current aws auth path.
auth_jwk_uri = ""

# Optional: custom domain (leave empty to use CloudFront default domain)
domain_name         = ""
acm_certificate_arn = ""
route53_zone_id     = ""

# SENSITIVE — inject via TF_VAR_* environment variables, do NOT set here:
# postgres_connection_string = "jdbc:postgresql://..."
# mongodb_connection_string  = "mongodb+srv://..."
# cloudfront_origin_secret   = "<random-uuid-or-strong-secret>"
# redis_url                  = "rediss://[:password@]host:port"  (Upstash requires rediss://)
# kafka_bootstrap_servers    = "pkc-xxxxx.region.aws.confluent.cloud:9092"
# kafka_sasl_username        = "<confluent-api-key>"
# kafka_sasl_password        = "<confluent-api-secret>"
