# =============================================================================
# Terraform Variable Examples — Wealth Management & Portfolio Tracker
# =============================================================================
#
# BOOTSTRAP SEQUENCE (run once before terraform init in this directory):
#   1. cd infrastructure/terraform/bootstrap
#   2. terraform init          # uses local state
#   3. terraform apply -var="state_bucket_name=my-tf-state" \
#                      -var="lock_table_name=my-tf-lock"
#   4. cd ..
#   5. terraform init -backend-config="bucket=my-tf-state" \
#                     -backend-config="dynamodb_table=my-tf-lock" \
#                     -backend-config="region=us-east-1"
#   6. terraform apply -var-file=terraform.tfvars
#
# SECRET INJECTION (never commit real secrets):
#   Sensitive variables are injected via environment variables in CI:
#   export TF_VAR_postgres_connection_string="jdbc:postgresql://..."
#   export TF_VAR_mongodb_connection_string="mongodb+srv://..."
#   export TF_VAR_cloudfront_origin_secret="<random-uuid>"
#
# =============================================================================

# Backend state (must match bootstrap outputs)
state_bucket_name = "my-wealth-tracker-tf-state"
lock_table_name   = "my-wealth-tracker-tf-lock"

# AWS configuration
aws_region                    = "us-east-1"
use_localstack                = false
# Paid RDS + ElastiCache (default false)
enable_aws_managed_database = false

# S3 artifact bucket
artifact_bucket_name = "my-wealth-tracker-artifacts"

# Frontend static export bucket
frontend_bucket_name = "my-wealth-tracker-frontend"

# Lambda Web Adapter layer ARN (region-specific, check AWS docs for latest)
lambda_adapter_layer_arn = "arn:aws:lambda:us-east-1:753240598075:layer:LambdaAdapterLayerX86:24"

# S3 keys for Lambda JARs (upload JARs before applying)
s3_key_api_gateway = "api-gateway/api-gateway.jar"
s3_key_portfolio   = "portfolio-service/portfolio-service.jar"
s3_key_market_data = "market-data-service/market-data-service.jar"
s3_key_insight     = "insight-service/insight-service.jar"

# JWK URI for JWT validation (aws profile)
auth_jwk_uri = "https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXX/.well-known/jwks.json"

# Optional: custom domain (leave empty to use CloudFront default domain)
domain_name         = ""
acm_certificate_arn = ""
route53_zone_id     = ""

# SENSITIVE — inject via TF_VAR_* environment variables, do NOT set here:
# postgres_connection_string = "jdbc:postgresql://..."
# mongodb_connection_string  = "mongodb+srv://..."
# cloudfront_origin_secret   = "<random-uuid-or-strong-secret>"
