# S3 backend configuration for the AWS Terraform root.
# Copy this file to backend-aws.hcl (without the .example suffix) and fill in
# the real values before running `terraform init -backend-config=backend-aws.hcl`.
# The real backend-aws.hcl should be kept out of version control.

# bucket         = "your-terraform-state-bucket"
# key            = "wealth-tracker/aws/terraform.tfstate"
# region         = "ap-south-1"
# dynamodb_table = "your-terraform-state-lock-table"
