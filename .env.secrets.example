# Terraform Backend (Bootstrap)
TF_STATE_BUCKET=vibhanshu-tf-state-2026
TF_LOCK_TABLE=vibhanshu-terraform-locks

# App Infrastructure Secrets
POSTGRES_CONNECTION_STRING=
MONGODB_CONNECTION_STRING=
AUTH_JWK_URI=
CLOUDFRONT_ORIGIN_SECRET=
# Redis (Upstash or ElastiCache) — used by api-gateway rate limiting and insight-service caching.
# Format: redis://[:password@]host[:port]  or  rediss://... for TLS (Upstash requires rediss://)
REDIS_URL=
# Kafka credentials — used by portfolio-service, market-data-service, and insight-service.
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# RDS (required by Terraform plan/apply — GitHub secret names must match)
RDS_MASTER_USERNAME=
RDS_MASTER_PASSWORD=

# AWS Credentials (if not using OIDC)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Warming — EventBridge Rules + API Destinations (Phase 2)
# TF_VAR_ENABLE_WARMING: "true" creates the 4 warming rules on next CI apply.
# TF_VAR_WARMING_ALARM_EMAIL: receives the SNS ConcurrentExecutions alert; must confirm subscription after first apply.
TF_VAR_ENABLE_WARMING=true
TF_VAR_WARMING_ALARM_EMAIL=

# ---------------------------------------------------------------------------
# Api-gateway downstream (PORTFOLIO / MARKET_DATA / INSIGHT)
# ---------------------------------------------------------------------------
# Day Zero (laptop): same default ports as Spring local / Compose published ports — no URL
# shape change when you move from `.env.secrets` to app defaults; only the host changes in cloud.
PORTFOLIO_SERVICE_URL=http://localhost:8081
MARKET_DATA_SERVICE_URL=http://localhost:8082
INSIGHT_SERVICE_URL=http://localhost:8083
#
# GitHub Actions / AWS Lambda: replace with each service’s HTTPS Lambda Function URL, e.g.
#   https://xxxxxxxx.lambda-url.<region>.on.aws/
# (from `terraform output` or Lambda → Configuration → Function URL.)
#
# Optional local “single stub” pattern (one process on :8080): set all three to http://localhost:8080
#
# Api-gateway running inside Docker Compose: use service DNS names (not localhost), e.g.
#   http://portfolio-service:8081 — see docker-compose.yml for the gateway service env.
#
# WARNING: ./scripts/sync-secrets.sh .env.secrets runs `gh secret set -f` and uploads every
# KEY=value in the file to the GitHub repo. Do not sync localhost URLs to a production repository;
# use real Function URLs (and other prod secrets) before syncing for prod.

# ---------------------------------------------------------------------------
# Azure — Phase 4 (Azure Container Apps deployment)
# ---------------------------------------------------------------------------
# OIDC identity for azure/login@v2 in deploy-azure.yml and terraform-azure.yml.
# These come from an Azure App Registration with a federated credential pointing
# at this GitHub repo. See docs/runbooks/AZURE_SECRETS_SETUP.md for setup steps.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

# Terraform remote state backend for infrastructure/terraform/azure/.
# Copy infrastructure/terraform/azure/backend-azure.hcl.example to
# backend-azure.hcl, fill in real values, then paste the entire file content
# here as a single-line or multi-line value.
# The terraform-azure.yml apply path writes this secret to backend-azure.hcl
# before running terraform init.
# Format: multi-line HCL, e.g.:
#   resource_group_name  = "wealth-tf-state-rg"
#   storage_account_name = "wealthtfstate"
#   container_name       = "tfstate"
#   key                  = "azure/terraform.tfstate"
AZURE_BACKEND_HCL=
